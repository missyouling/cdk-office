# CDK-Office 环境配置模板
# 复制此文件为 .env 并根据实际环境修改配置

# ======================================
# 基础配置
# ======================================
COMPOSE_PROJECT_NAME=cdk-office
DOMAIN=localhost
VERSION=latest
COMMIT_SHA=unknown
BUILD_TIME=2024-01-01T00:00:00Z

# ======================================
# 端口配置
# ======================================
HTTP_PORT=80
HTTPS_PORT=443
APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
STIRLING_PDF_PORT=8081
KKFILEVIEW_PORT=8012
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ELASTICSEARCH_PORT=9200

# ======================================
# 应用配置
# ======================================
APP_ENV=production
GIN_MODE=release
APP_DEBUG=false

# ======================================
# 数据库配置
# ======================================
DB_HOST=postgres
DB_NAME=cdk_office
DB_USER=cdk_office
DB_PASSWORD=SecurePassword123!
DB_SSL_MODE=disable

# 数据库性能配置
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300s
DB_CONN_MAX_IDLE_TIME=300s

# ======================================
# Redis配置
# ======================================
REDIS_HOST=redis
REDIS_PASSWORD=RedisSecure123!
REDIS_DB=0
REDIS_POOL_SIZE=10

# ======================================
# 第三方服务配置
# ======================================
STIRLING_PDF_URL=http://stirling-pdf:8080
KKFILEVIEW_URL=http://kkfileview:8012

# ======================================
# 文件存储配置
# ======================================
UPLOAD_PATH=/app/uploads
PDF_RESULTS_PATH=/app/pdf_results
CACHE_PATH=/app/cache
MAX_UPLOAD_SIZE=200MB

# ======================================
# 性能优化配置
# ======================================
# 缓存配置
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# 限流配置
API_RATE_LIMIT=1000
UPLOAD_RATE_LIMIT=10

# 并发控制
MAX_CONCURRENCY=1000

# ======================================
# 监控和日志配置
# ======================================
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
LOG_LEVEL=info

# Grafana配置
GRAFANA_PASSWORD=GrafanaSecure123!
GRAFANA_SECRET_KEY=grafana_secret_key_2024

# ======================================
# SSL配置
# ======================================
SSL_EMAIL=admin@example.com
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ======================================
# OAuth配置（如果使用）
# ======================================
# OAUTH_CLIENT_ID=your_client_id
# OAUTH_CLIENT_SECRET=your_client_secret
# OAUTH_REDIRECT_URL=https://yourdomain.com/auth/callback

# ======================================
# 邮件配置（如果使用）
# ======================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM=noreply@yourdomain.com

# ======================================
# 云存储配置（如果使用）
# ======================================
# 阿里云OSS
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET_NAME=your_bucket_name

# AWS S3
# S3_REGION=us-west-2
# S3_ACCESS_KEY_ID=your_access_key_id
# S3_SECRET_ACCESS_KEY=your_secret_access_key
# S3_BUCKET_NAME=your_bucket_name

# ======================================
# 微服务配置（如果使用）
# ======================================
# SERVICE_REGISTRY_URL=http://consul:8500
# SERVICE_NAME=cdk-office
# SERVICE_VERSION=1.0.0

# ======================================
# 开发环境配置
# ======================================
# 开发模式下可以启用的配置
# DEV_AUTO_RELOAD=true
# DEV_MOCK_SERVICES=true
# DEV_DEBUG_SQL=true

# ======================================
# 安全配置
# ======================================
# 会话配置
SESSION_SECRET=your_session_secret_key_2024
SESSION_TIMEOUT=3600

# JWT配置（如果使用）
# JWT_SECRET=your_jwt_secret_key_2024
# JWT_EXPIRE_TIME=24h

# CORS配置
# CORS_ALLOWED_ORIGINS=*
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=*

# ======================================
# 备份配置
# ======================================
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点备份
BACKUP_RETENTION_DAYS=7

# ======================================
# 自定义配置
# ======================================
# 在这里添加其他自定义配置
# CUSTOM_CONFIG_1=value1
# CUSTOM_CONFIG_2=value2